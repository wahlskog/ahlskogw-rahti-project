@apiUrl = https://fw-teaching.fi/demo/wdbocms/api/v1/products/

### Get all products
GET {{apiUrl}}
### Get one product
GET {{apiUrl}}/1002
### Create a new product
POST {{apiUrl}}
Content-Type: application/json

    {
      "name": "Jeans",
      "price": 49
    }

### Update a product (PATCH)
PATCH {{apiUrl}}/1001
Content-Type: application/json

    {
      "price": 29
    }

### Update a product (PUT)
PUT {{apiUrl}}/1001
Content-Type: application/json

    {
        "name": "Shirt",
      "price": 25
    }

### Delete a product
DELETE {{apiUrl}}/1005
